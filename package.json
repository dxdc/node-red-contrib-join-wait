        "url": "git+https://github.com/dxdc/node-red-contrib-join-wait.git"
    },
    "bugs": {
        "url": "https://github.com/dxdc/node-red-contrib-join-wait/issues"
    },
    "funding": [
        {
            "type": "individual",
            "url": "https://paypal.me/ddcaspi"
        },
        {
            "type": "github",
            "url": "https://github.com/sponsors/dxdc"
        }
    ],
    "main": "join-wait.js",
    "engines": {
        "node": ">=18.5"
    },
    "files": [
        "join-wait.js",
        "join-wait.html",
        "lib/",
        "icons/",
        "examples/",
        "LICENSE",
        "README.md",
        "CHANGELOG.md"
    ],
    "keywords": [
        "node-red",
        "node-red-contrib",
        "join",
        "merge",
        "wait",
        "timeout",
        "parallel",
        "synchronize",
        "coordinate",
