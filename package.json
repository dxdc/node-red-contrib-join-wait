        "events",
        "iot",
        "home-automation"
    ],
    "node-red": {
        "version": ">=3.0.0",
        "nodes": {
            "join-wait": "join-wait.js"
        }
    },
    "dependencies": {
        "jsonata": "^2.0.5"
    },
    "devDependencies": {
        "@eslint/js": "^9.10.0",
        "@types/node-red": "^1.3.5",
        "c8": "^10.1.2",
        "cspell": "^8.13.3",
        "eslint": "^9.10.0",
        "eslint-plugin-mocha": "^10.5.0",
