            { "p": "payload", "v": "hello-1", "vt": "str" }
        ],
        "repeat": "",
        "crontab": "",
        "once": false,
        "onceDelay": "",
        "topic": "path_1",
        "x": 130,
        "y": 100,
        "wires": [["qs-jw"]]
    },
    {
        "id": "qs-i2",
        "type": "inject",
        "z": "qs-tab",
        "name": "path_2",
        "props": [
            { "p": "topic", "vt": "str" },
            { "p": "payload", "v": "hello-2", "vt": "str" }
        ],
        "repeat": "",
        "crontab": "",
        "once": false,
        "onceDelay": "",
        "topic": "path_2",
        "x": 130,
        "y": 160,
        "wires": [["qs-jw"]]
    },
    {
        "id": "qs-jw",
        "type": "join-wait",
        "z": "qs-tab",
        "name": "wait 5s",
        "paths": ["path_1", "path_2"],
        "pathsToExpire": [],
        "useRegex": false,
        "warnUnmatched": true,
        "pathTopic": "topic",
